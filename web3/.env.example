# ── Wallet ────────────────────────────────────────────────────────────────
# Private key of the deployer account (with or without 0x prefix).
# Must hold Sepolia ETH for gas.  Get testnet ETH at https://sepoliafaucet.com
DEPLOYER_PRIVATE_KEY=

# ── RPC (optional) ────────────────────────────────────────────────────────
# Defaults to https://rpc.sepolia.org if unset.
# SEPOLIA_RPC_URL=

# ── Etherscan verification (optional) ─────────────────────────────────────
# ETHERSCAN_API_KEY=
